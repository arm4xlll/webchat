<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty name="LOG_FILE" source="logging.file.name" defaultValue="logs/webchat.log"/>
    <springProperty name="LOG_LEVEL_APP" source="logging.level.com.webchat" defaultValue="INFO"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"/>
            <onMismatch>NEUTRAL</onMismatch>
            <onMatch>NEUTRAL</onMatch>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.gz</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress broken pipe / client abort noise -->
    <!-- dispatcherServlet logs IOException: Broken pipe when SSE client disconnects -->
    <logger name="org.apache.catalina.core.ContainerBase" level="OFF"/>
    <logger name="org.apache.catalina.connector" level="OFF"/>
    <logger name="org.apache.coyote.http11.Http11Processor" level="WARN"/>

    <!-- Suppress broken pipe during SSE/async response writing -->
    <logger name="org.springframework.web.servlet.mvc.method.annotation.ResponseBodyEmitterReturnValueHandler" level="WARN"/>
    <logger name="org.springframework.web.servlet.mvc.method.annotation.HttpEntityMethodProcessor" level="WARN"/>

    <logger name="com.webchat" level="${LOG_LEVEL_APP}"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
